{
  "name": "backend",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "src/main.ts",
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn src/main.ts",
    "seed:referral": "node dist/scripts/seed-referral-once.js",
    "swap-user-ids": "ts-node -r tsconfig-paths/register src/scripts/swap-user-ids.ts",
    "add-balance": "ts-node -r tsconfig-paths/register src/scripts/add-balance.ts",
    "verify-email": "ts-node -r tsconfig-paths/register src/scripts/verify-email-user.ts",
    "set-password": "ts-node -r tsconfig-paths/register src/scripts/set-password.ts",
    "check-user": "ts-node -r tsconfig-paths/register src/scripts/check-user.ts",
    "audit:auth-payments": "ts-node src/scripts/audit-auth-payments.ts",
    "fix:auth-payments-data": "ts-node src/scripts/audit-auth-payments.ts --fix",
    "seed:questions": "node dist/scripts/seed-questions.js",
    "backfill:tournament-resolutions": "ts-node -r tsconfig-paths/register src/scripts/backfill-tournament-round-resolutions.ts"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/passport-jwt": "^4.0.1",
    "bcryptjs": "^3.0.3",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.22",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/jest": "^30.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "better-sqlite3": "^12.6.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
