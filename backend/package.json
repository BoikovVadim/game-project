{
  "name": "backend",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "src/main.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/common/stats-exception.filter.ts\" \"src/users/users.controller.ts\" \"src/users/dto/**/*.ts\" \"src/admin/admin.controller.ts\" \"src/payments/payments.controller.ts\" \"src/payments/dto/**/*.ts\" \"src/tournaments/tournaments.controller.ts\"",
    "test": "tsx --test src/tournaments/domain/*.test.ts src/tournaments/question-generators/*.test.ts src/users/*.test.ts",
    "test:e2e": "npm run build && node dist/scripts/e2e-health-check.js",
    "test:all": "npm run test && npm run test:e2e",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn src/main.ts",
    "seed:referral": "node dist/scripts/seed-referral-once.js",
    "swap-user-ids": "ts-node -r tsconfig-paths/register src/scripts/swap-user-ids.ts",
    "add-balance": "ts-node -r tsconfig-paths/register src/scripts/add-balance.ts",
    "verify-email": "ts-node -r tsconfig-paths/register src/scripts/verify-email-user.ts",
    "set-password": "ts-node -r tsconfig-paths/register src/scripts/set-password.ts",
    "check-user": "ts-node -r tsconfig-paths/register src/scripts/check-user.ts",
    "audit:auth-payments": "ts-node src/scripts/audit-auth-payments.ts",
    "audit:tournaments": "ts-node src/scripts/audit-tournaments.ts",
    "audit:finance-ledger": "ts-node src/scripts/audit-finance-ledger.ts",
    "fix:auth-payments-data": "ts-node src/scripts/audit-auth-payments.ts --fix",
    "fix:activate-unfinished-tournaments": "ts-node -r tsconfig-paths/register src/scripts/activate-unfinished-tournaments.ts",
    "fix:admin-credit-ledger": "ts-node src/scripts/normalize-admin-credit-ledger.ts",
    "fix:ruble-ledger": "ts-node src/scripts/repair-ruble-ledger.ts",
    "fix:finance-ledger": "ts-node src/scripts/repair-finance-ledger.ts",
    "fix:manual-finance-cases": "ts-node src/scripts/resolve-approved-manual-finance-cases.ts",
    "seed:questions": "node dist/scripts/seed-questions.js",
    "backfill:tournament-resolutions": "ts-node -r tsconfig-paths/register src/scripts/backfill-tournament-round-resolutions.ts"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/passport-jwt": "^4.0.1",
    "bcryptjs": "^3.0.3",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.17"
  },
  "overrides": {
    "file-type": "21.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/testing": "^11.1.16",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/jest": "^30.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "better-sqlite3": "^12.6.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
