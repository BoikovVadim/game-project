# Копируйте в .env и заполните для отправки писем подтверждения регистрации

# Путь к SQLite (если админка не видит пользователей — укажите полный путь к backend/db.sqlite)
# DATABASE_PATH=/полный/путь/к/проекту/backend/db.sqlite

# SMTP (например Gmail, Yandex, Mail.ru)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Адрес отправителя (по умолчанию = SMTP_USER)
MAIL_FROM=noreply@yourdomain.com

# URL приложения для ссылок в письмах и возврата после оплаты
APP_URL=http://localhost:3000

# ЮKassa (https://yookassa.ru/)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Robokassa (https://robokassa.ru/)
# В личном кабинете Robokassa укажите Result URL: https://ваш-домен/payments/webhook/robokassa/result
ROBOBASSA_MERCHANT_LOGIN=
ROBOBASSA_PASSWORD1=
ROBOBASSA_PASSWORD2=

# Админка: чтобы назначить первого админа, в SQLite выполните:
# UPDATE user SET isAdmin = 1 WHERE id = ВАШ_USER_ID;
