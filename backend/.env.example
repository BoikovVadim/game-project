# Копируйте в backend/.env и заполните перед локальным запуском или деплоем

# Production/runtime
NODE_ENV=development
PORT=3001
JWT_SECRET=

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=legend
DB_PASS=
DB_NAME=legendgames

# SMTP (например Gmail, Yandex, Mail.ru)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=

# Адрес отправителя (по умолчанию = SMTP_USER)
MAIL_FROM=noreply@yourdomain.com

# URL приложения для ссылок в письмах и возврата после оплаты
APP_URL=http://localhost:3000

# Разрешённые origin'ы для CORS в production
CORS_ORIGINS=http://localhost:3000

# ЮKassa (https://yookassa.ru/)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Robokassa (https://robokassa.ru/)
# В личном кабинете Robokassa укажите Result URL: https://ваш-домен/payments/webhook/robokassa/result
ROBOBASSA_MERCHANT_LOGIN=
ROBOBASSA_PASSWORD1=
ROBOBASSA_PASSWORD2=
